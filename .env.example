# Hera Logistics SMS System - Environment Variables

# Django
DJANGO_SECRET_KEY=change-this-to-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (set DB_ENGINE=mysql to use MySQL, otherwise SQLite)
DB_ENGINE=sqlite3
DB_NAME=hera
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery (set to False in production with a running Celery worker)
CELERY_ALWAYS_EAGER=True

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_MESSAGING_SERVICE_SID=your_messaging_service_sid

# Google reCAPTCHA v2
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
